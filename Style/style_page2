html, body {
    height: 100%;
    margin: 0;
}

body {
    color: white;
    display: flex;
    flex-direction: column;
    text-align: center;
}

main {
    font-family: 'Courier New', Courier, monospace;
    flex: 1;
}

.back-video {
    position: absolute;
    right: 0;
    bottom: 0;
    z-index: -1;
}

@media (max-aspect-ratio: 16/9) {
    .back-video {
        width: auto;
        height: 100%;
    }
}